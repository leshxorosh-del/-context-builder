# ===========================================
# Context Builder — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Node environment
NODE_ENV=development

# ===========================================
# Backend Server
# ===========================================
PORT=3001
HOST=localhost
API_BASE_URL=http://localhost:3001

# ===========================================
# Frontend
# ===========================================
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# ===========================================
# PostgreSQL
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=context_builder
POSTGRES_USER=context_user
POSTGRES_PASSWORD=your_secure_password_here

# Full connection string (alternative)
DATABASE_URL=postgresql://context_user:your_secure_password_here@localhost:5432/context_builder

# ===========================================
# Neo4j (Graph Database)
# ===========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ===========================================
# Redis
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Full connection string (alternative)
REDIS_URL=redis://localhost:6379

# ===========================================
# JWT Authentication
# ===========================================
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# LLM Provider (OpenAI)
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096

# Alternative: Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-opus-20240229

# ===========================================
# Notifications
# ===========================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=Context Builder <noreply@contextbuilder.app>

# Slack (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ===========================================
# CORS
# ===========================================
CORS_ORIGIN=http://localhost:5173

# ===========================================
# Session
# ===========================================
SESSION_SECRET=your_session_secret_here
